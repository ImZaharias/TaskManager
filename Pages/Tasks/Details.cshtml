@page "{id:int}"
@model TaskManager.Pages.Tasks.DetailsModel
@{
    ViewData["Title"] = "Task";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">@Model.Task!.Title</h3>
        <div class="text-muted">Project: @Model.Task.Project.Name</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-page="Edit" asp-route-id="@Model.Task.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-page="Delete" asp-route-id="@Model.Task.Id">Delete</a>
        <a class="btn btn-link" asp-page="Index">Back</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="sf-card mb-3">
    <div class="row mb-2">
        <div class="col-md-3 text-muted">Status</div>
        <div class="col-md-9 fw-semibold">@Model.Task.Status</div>
    </div>
    <div class="row mb-2">
        <div class="col-md-3 text-muted">Assigned To</div>
        <div class="col-md-9">@(Model.Task.AssignedToUser?.DisplayName ?? "-")</div>
    </div>
    <div class="row">
        <div class="col-md-3 text-muted">Description</div>
        <div class="col-md-9">@Model.Task.Description</div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="sf-card">
            <h5 class="mb-3">Quick Action: Change Status</h5>
            <form method="post" asp-page-handler="ChangeStatus">
                <select class="form-select mb-2" name="newStatus">
                    @foreach (var s in Model.StatusOptions)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">Apply</button>
            </form>
            <div class="text-muted mt-2" style="font-size:.9rem;">
                Rules: ToDoâ†’InProgress/Blocked, InProgressâ†’Done/Blocked, Blockedâ†’InProgress, Doneâ†’none
            </div>
        </div>
    </div>

<div class="col-md-6">
    <div class="sf-card">
        <h5 class="mb-3">Quick Action: Assign</h5>
        <form method="post" asp-page-handler="Assign">
            <select class="form-select mb-2" name="assignedToUserId">
                <option value="">(Unassigned)</option>
                @foreach (var u in Model.UserOptions)
                {
                    <option value="@u.Id">@u.DisplayName (@u.Email)</option>
                }
            </select>
            <button class="btn btn-outline-primary" type="submit">Save</button>
        </form>
    </div>
</div>
<div class="sf-card mt-3">
<div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="mb-0">Comments (Related List)</h5>
</div>

<form method="post" asp-page-handler="AddComment" class="mb-3">
    <div class="mb-2">
        <textarea class="form-control" name="body" rows="2" placeholder="Add a comment..."></textarea>
    </div>
    <button class="btn btn-outline-primary" type="submit">Add Comment</button>
</form>

@if (Model.Comments.Count == 0)
{
    <div class="text-muted">No comments yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var c in Model.Comments)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <div class="fw-semibold">@c.CreatedByUser.DisplayName</div>
                    <div class="text-muted" style="font-size:.9rem;">@c.CreatedAtUtc.ToLocalTime().ToString("HH:mm")</div>
                </div>
                <div>@c.Body</div>
            </div>
        }
    </div>
}
<div class="sf-card mt-3">
    <h5>Tags (Related List)</h5>

    <form method="post" asp-page-handler="AddTag" class="mb-3">
        <select name="tagId" class="form-select">
            @foreach (var tag in Model.AllTags)
            {
                <option value="@tag.Id">@tag.Name</option>
            }
        </select>
        <button class="btn btn-outline-primary mt-2">Add Tag</button>
    </form>

    @if (Model.CurrentTags.Count == 0)
    {
        <div class="text-muted">No tags assigned.</div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var tag in Model.CurrentTags)
            {
                <form method="post" asp-page-handler="RemoveTag">
                    <input type="hidden" name="tagId" value="@tag.Id" />
                    <button class="badge bg-primary border-0">
                        @tag.Name âś•
                    </button>
                </form>
            }
        </div>
    }
</div>