@page
@model TaskManager.Pages.Tasks.CreateModel
@{
    ViewData["Title"] = "New Task";
}

<div class="sf-card">
    <h3 class="mb-3">New Task</h3>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Project</label>
            <select class="form-select" asp-for="Input.ProjectId" asp-items="Model.ProjectOptions"></select>
            <span class="text-danger" asp-validation-for="Input.ProjectId"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input class="form-control" asp-for="Input.Title" />
            <span class="text-danger" asp-validation-for="Input.Title"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" asp-for="Input.Description" rows="3"></textarea>
        </div>

        <button class="btn btn-primary" type="submit">Create</button>
        <a class="btn btn-link" asp-page="Index">Cancel</a>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }