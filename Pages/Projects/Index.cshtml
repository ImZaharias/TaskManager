@page
@model TaskManager.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Projects</h3>
    <a class="btn btn-primary" asp-page="Create">New Project</a>
</div>

<div class="sf-card mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Search</label>
            <input class="form-control" name="q" value="@Model.Q" placeholder="Project name..." />
        </div>
        <div class="col-md-auto">
            <button class="btn btn-outline-secondary" type="submit">Filter</button>
            <a class="btn btn-link" asp-page="Index">Clear</a>
        </div>
    </form>
</div>

<div class="sf-card">
    @if (Model.Projects.Count == 0)
    {
        <div class="text-muted">No projects found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Projects)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@p.Name</div>
                            <div class="text-muted" style="font-size:0.9rem;">@p.Description</div>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-page="Details" asp-route-id="@p.Id">Open</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@p.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@p.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>