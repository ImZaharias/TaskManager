@page "{id:int}"
@model TaskManager.Pages.Projects.DetailsModel
@using TMTaskStatus = TaskManager.Domain.Enums.TaskStatus
@{
    ViewData["Title"] = "Project";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">@Model.Project!.Name</h3>
        <div class="text-muted">@Model.Project.Description</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/Tasks/Create" asp-route-projectId="@Model.Project.Id">New Task</a>
        <a class="btn btn-outline-secondary" asp-page="Edit" asp-route-id="@Model.Project.Id">Edit</a>
        <a class="btn btn-outline-danger" asp-page="Delete" asp-route-id="@Model.Project.Id">Delete</a>
        <a class="btn btn-link" asp-page="Index">Back</a>
    </div>
</div>

<div class="sf-card mb-3">
    <div class="row">
        <div class="col-md-4 text-muted">OwnerUserId</div>
        <div class="col-md-8">@Model.Project.OwnerUserId</div>
    </div>
</div>

<div class="sf-card">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Tasks (Related List)</h5>
        <a asp-page="/Tasks/Index" class="btn btn-sm btn-outline-secondary">View All Tasks</a>
    </div>

    @foreach (var status in Enum.GetValues<TaskManager.Domain.Enums.TaskStatus>())
    {
        var list = Model.TasksByStatus.ContainsKey(status) ? Model.TasksByStatus[status] : new();
        <div class="mt-3">
            <div class="fw-semibold">@status (@list.Count)</div>

            @if (list.Count == 0)
            {
                <div class="text-muted" style="font-size:.9rem;">No tasks</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                        @foreach (var t in list)
                        {
                            <tr>
                                <td class="fw-semibold">@t.Title</td>
                                <td style="width:160px;">
                                    <a class="btn btn-sm btn-outline-primary" asp-page="/Tasks/Details" asp-route-id="@t.Id">Open</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>